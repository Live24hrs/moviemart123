# OpenRouter (already used by your chat)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Instagram handle for the DM button
NEXT_PUBLIC_INSTAGRAM_HANDLE=your_instagram_handle

# Adsterra ad unit keys (optional)
# Put the `key` Adsterra gives you for each ad unit.
NEXT_PUBLIC_ADSTERRA_DISPLAY_1=0b7d5447f8ac6537721c9df29e968745
NEXT_PUBLIC_ADSTERRA_DISPLAY_2=0b7d5447f8ac6537721c9df29e968745
NEXT_PUBLIC_ADSTERRA_VIDEO_1=0b7d5447f8ac6537721c9df29e968745
NEXT_PUBLIC_ADSTERRA_VIDEO_2=0b7d5447f8ac6537721c9df29e968745
